# S2S Translator API — Environment Variables
# Copy to .env and fill in your values

# ── Database ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/s2s_translator

# ── Models ─────────────────────────────────────────────────────────
MODELS_DIR=./models_cache
WARM_MODELS=false           # set true to load all models at startup

# ── Audio storage ──────────────────────────────────────────────────
AUDIO_OUTPUT_DIR=./audio_outputs
AUDIO_UPLOAD_DIR=./audio_uploads
MAX_AUDIO_MB=25

# ── Auth ───────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 hours

# ── CORS ───────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Server ─────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
